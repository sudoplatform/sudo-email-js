  "scripts": {
    "prepare": "husky",
    "lint": "npm-run-all --parallel lint:eslint lint:prettier",
    "lint:eslint": "eslint test/ src/",
    "lint:prettier": "prettier -l \"test/**/*.{js,jsx,ts,tsx,yml}\" \"src/**/*.{js,jsx,ts,tsx,yml}\"",
    "codegen": "graphql-codegen -c graphql/codegen.ts",
    "audit-with-suppressions": "true",
    "verify": "true",
    "unit-test": "vitest run test/unit",
    "smoketest": "yarn unit-test && vitest run test/integration/smoketest",
    "integration-test": "vitest run test/integration",
    "clean": "rm -rf ./docs ./lib ./cjs ./types",
    "build": "yarn codegen && yarn lint && yarn build:transpile && yarn build:docs",
    "build:transpile": "concurrently \"yarn build:transpile:declarations\" \"yarn build:transpile:cjs\" \"yarn build:transpile:esm\"",
    "build:transpile:declarations": "tsc --project tsconfig.declarations.json",
    "build:transpile:cjs": "tsc --project tsconfig.commonjs.json",
    "build:transpile:esm": "tsc",
    "build:docs": "typedoc --readme \"${README_FILE:-$(test -f README.external.md && echo README.external.md || echo README.md)}\" --treatWarningsAsErrors --excludePrivate --out docs src/index.ts"
  },
  "main": "./cjs/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./lib/index.js",
      "require": "./cjs/index.js",
      "default": "./lib/index.js"
    }
  },
